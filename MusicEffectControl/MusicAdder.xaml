<Window x:Class="MusicEffectControl.MusicAdder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicEffectControl"
        mc:Ignorable="d"
        Title="MusicAdder" Height="378" Width="480" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" InputMethod.IsInputMethodEnabled="False">
    
    <Window.Resources>

        <Style x:Key="ListViewItemStyle" TargetType="{x:Type ListViewItem}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter  Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13.5"/>

            <Setter Property="Foreground"  Value="#FF730202"/>
        </Style>

    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="300"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <ListBox Name="Tags" SelectionChanged="Tags_SelectionChanged" Grid.Column="0" Height="300">
            </ListBox>

            <Grid Grid.Column="1">
                <ListView Name="MusicList" Grid.Row="0" ItemContainerStyle="{StaticResource ListViewItemStyle}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="序号" Width="100"   DisplayMemberBinding="{Binding ID}"/>
                            <GridViewColumn Header="音效名称" Width="230"   DisplayMemberBinding="{Binding MusicName}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0 7 0 0">
                <Label>
                    分类:
                </Label>
                <ComboBox Name="LocalTags" Width="100">
                </ComboBox>

                <Button Margin="5 0 0 0" Click="AddMusicFromWeb">
                    添加网络音效
                </Button>


                <Button Margin="5 0 0 0" Click="AddLocal">
                    添加本地音效
                </Button>
            </StackPanel>
           
        </Grid>
    </Grid>

   

</Window>
